<?xml version='1.0'?>

<robot name="mogi_bot" xmlns:xacro="http://www.ros.org/wiki/xacro" xmlns:gz="http://gazebosim.org/schema">

  <!-- STEP 3 - Gazebo plugin -->
  <xacro:include filename="$(find bme_ros2_navigation)/urdf/mogi_bot.gazebo" />

  <!-- STEP 4 - RViz colors -->
  <xacro:include filename="$(find bme_ros2_navigation)/urdf/materials.xacro" />

  <!-- STEP 1 - Robot chassis -->
  <link name="base_footprint"></link>

  <joint name="base_footprint_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_footprint"/>
    <child link="base_link" />
  </joint>

  <link name='base_link'>
    <pose>0 0 0.1 0 0 0</pose>

    <inertial>
      <mass value="15.0"/>
      <origin xyz="0.0 0 0" rpy=" 0 0 0"/>
      <inertia
          ixx="0.0625" ixy="0" ixz="0"
          iyy="0.2125" iyz="0"
          izz="0.25"
      />
    </inertial>

    <collision name='collision'>
      <origin xyz="0 0 0" rpy=" 0 0 0"/> 
      <geometry>
        <box size=".4 .2 .1"/>
      </geometry>
    </collision>

    <visual name='base_link_visual'>
      <origin xyz="0 0 -0.075" rpy=" 0 0 0"/>
      <geometry>
        <mesh filename="package://bme_ros2_navigation/meshes/base_link_1.stl" scale="4 3.1 3.1" />
      </geometry>
       <material name="blue"/>
    </visual>

  </link>

  <!-- STEP 2 - Mecanum Wheels (4x via macro) -->
  <xacro:macro name="wheel" params="prefix x_pos y_pos fdir mesh_file">

    <joint type="continuous" name="${prefix}_wheel_joint">
      <origin xyz="${x_pos} ${y_pos} 0" rpy="-1.5707 0 0"/>
      <child link="${prefix}_wheel"/>
      <parent link="base_link"/>
      <axis xyz="0 0 1" rpy="0 0 0"/>
      <limit effort="10000" velocity="10"/>
      <dynamics damping="1.0" friction="1.0"/>
    </joint>

    <link name='${prefix}_wheel'>
      <inertial>
        <mass value="2.0"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia
            ixx="0.145833" ixy="0" ixz="0"
            iyy="0.145833" iyz="0"
            izz="0.125"
        />
      </inertial>

      <collision>
        <geometry>
          <sphere radius=".1"/>
        </geometry>
      </collision>

      <visual name='${prefix}_wheel_visual'>
        <origin xyz="0 0 0" rpy="1.5707 0 0"/>
        <geometry>
          <mesh filename="package://bme_ros2_navigation/meshes/${mesh_file}" scale="0.002 .002 0.002"/>
        </geometry>
        <material name="grey">
          <color rgba="0 1 0 1"/>
        </material>
      </visual>
    </link>

    <gazebo reference="${prefix}_wheel">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>0.0</mu2>
              <fdir1 gz:expressed_in="base_footprint">${fdir}</fdir1>
            </ode>
          </friction>
        </surface>
      </collision>
    </gazebo>

  </xacro:macro>

  <xacro:wheel prefix="front_left"  x_pos="0.15"  y_pos="0.17"  fdir="1 -1 0" mesh_file="mecanum_wheel_left.STL"/>
  <xacro:wheel prefix="rear_left"   x_pos="-0.15" y_pos="0.17"  fdir="1 1 0"  mesh_file="mecanum_wheel_right.STL"/>
  <xacro:wheel prefix="front_right" x_pos="0.15"  y_pos="-0.17" fdir="1 1 0"  mesh_file="mecanum_wheel_right.STL"/>
  <xacro:wheel prefix="rear_right"  x_pos="-0.15" y_pos="-0.17" fdir="1 -1 0" mesh_file="mecanum_wheel_left.STL"/>

  <gazebo reference="base_link">
    <mu1>0.000002</mu1>
    <mu2>0.000002</mu2>
  </gazebo>

  <!-- Camera -->
  <joint type="fixed" name="camera_joint">
    <origin xyz="0.155 0 0.095" rpy="0 0 0"/>
    <child link="camera_link"/>
    <parent link="base_link"/>
    <axis xyz="0 1 0" />
  </joint>

  <link name='camera_link'>
    <pose>0 0 0 0 0 0</pose>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
          ixx="1e-6" ixy="0" ixz="0"
          iyy="1e-6" iyz="0"
          izz="1e-6"
      />
    </inertial>

    <collision name='collision'>
      <origin xyz="-0.02 0 0" rpy="0 0 0"/> 
      <geometry>
        <box size=".03 .03 .03"/>
      </geometry>
    </collision>

    <visual name='camera_link_visual'>
      <origin xyz="-0.065 0 0" rpy="1.55 0 1.55"/>
      <geometry>
         <mesh filename="package://bme_ros2_navigation/meshes/d435.stl" scale="1 1 1" />
      </geometry>
    </visual>

  </link>

  <gazebo reference="camera_link">
    <material>Gazebo/Red</material>
  </gazebo>

  <joint type="fixed" name="camera_optical_joint">
    <origin xyz="0 0 0" rpy="-1.5707 0 -1.5707"/>
    <child link="camera_link_optical"/>
    <parent link="camera_link"/>
  </joint>

  <link name="camera_link_optical">
  </link>

  <!-- IMU -->
  <joint name="imu_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link"/>
    <child link="imu_link" />
  </joint>

  <link name="imu_link">
  </link>


  <!-- Lidar -->
  <joint type="fixed" name="scan_joint">
    <origin xyz="-0.115 0 0.15" rpy="0 0 0"/>
    <child link="scan_link"/>
    <parent link="base_link"/>
    <axis xyz="0 1 0" rpy="0 0 0"/>
  </joint>

  <link name='scan_link'>
    <inertial>
      <mass value="1e-5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
          ixx="1e-6" ixy="0" ixz="0"
          iyy="1e-6" iyz="0"
          izz="1e-6"
      />
    </inertial>
    <collision name='collision'>
      <origin xyz="0 0 0" rpy="0 0 0"/> 
      <geometry>
        <box size=".1 .1 .1"/>
      </geometry>
    </collision>

    <visual name='scan_link_visual'>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename = "package://bme_ros2_navigation/meshes/laser_link.STL" scale="1 1 1"/>
      </geometry>
       <material name="black"/>
    </visual>

  </link>

  <gazebo reference="scan_link">
    <selfCollide>false</selfCollide>
    <mu1 value="0.05" />
    <mu2 value="0.05" />
  </gazebo>

</robot>
